# =================================================================
# == Environment Variables — Photography Portfolio               ==
# =================================================================
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must never be committed.

# --- Nextcloud (photo albums via WebDAV) ---
# Each folder inside Lightroom/Portfolio becomes one album.
# Generate an app password: Nextcloud → Settings → Security → App passwords
NEXTCLOUD_URL="https://cloud.your-domain.com"
NEXTCLOUD_USER="your-nextcloud-username"
NEXTCLOUD_PASSWORD="your-app-password"

# --- Payload CMS (approval workflow + reviews) ---
NEXT_PUBLIC_CMS_URL="https://cms.your-domain.com"

# --- SMTP (contact form + transactional email) ---
# The contact form, auto-reply, and approval emails all use this transport.
SMTP_HOST="web207.dogado.net"
SMTP_PORT="465"
SMTP_USER="admin@your-domain.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="photosby@your-domain.com"   # alias shown to recipients
ADMIN_EMAIL="admin@your-domain.com"    # where contact form submissions land

# --- Personal Information (Imprint & Privacy Policy) ---
NEXT_PUBLIC_FULL_NAME="Your Full Name"
NEXT_PUBLIC_EMAIL_ADDRESS="your.email@example.com"
NEXT_PUBLIC_PHONE_NUMBER="[optional]"
NEXT_PUBLIC_STREET_ADDRESS="Your Street 123"
NEXT_PUBLIC_CITY_ADDRESS="12345 Your City"

# --- Social Media ---
NEXT_PUBLIC_LINKEDIN_USERNAME="your-linkedin-username"
NEXT_PUBLIC_INSTAGRAM_USERNAME="your-instagram-username"

# --- reCAPTCHA v3 (Leave a Review page) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your_recaptcha_site_key"

# --- Domain ---
NEXT_PUBLIC_PHOTOGRAPHY_DOMAIN="photos.your-domain.com"
